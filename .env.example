# ============================================================
# Mission Control — Environment Configuration
# Copy this file to .env.local and fill in your values.
# ============================================================

# Path to your OpenClaw state directory (the .openclaw folder)
# macOS/Linux example: /Users/yourname/.openclaw
# Windows example:     C:\Users\yourname\.openclaw
OPENCLAW_HOME=

# OpenClaw Gateway connection
OPENCLAW_GATEWAY_HOST=127.0.0.1
OPENCLAW_GATEWAY_PORT=18789

# Gateway auth token (find in your openclaw.json under auth.token, or leave blank if no auth)
OPENCLAW_GATEWAY_TOKEN=
NEXT_PUBLIC_GATEWAY_TOKEN=

# Frontend gateway connection (same as above, for browser-side requests)
NEXT_PUBLIC_GATEWAY_HOST=127.0.0.1
NEXT_PUBLIC_GATEWAY_PORT=18789

# Optional: restrict which hosts can access Mission Control (comma-separated)
MC_ALLOWED_HOSTS=

# Optional: override the memory browser directory (defaults to OPENCLAW_HOME/workspace-main)
OPENCLAW_MEMORY_DIR=
OPENCLAW_MEMORY_ALLOWED_PREFIXES=

# Optional: misc
OPENCLAW_TOOLS_PROFILE=
API_KEY=
