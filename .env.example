# ============================================================
# Mission Control — Environment Configuration
# Copy this file to .env.local and fill in your values.
# ============================================================

# Path to your OpenClaw state directory (the .openclaw folder)
# macOS/Linux: /Users/yourname/.openclaw or /home/yourname/.openclaw
# Windows:     C:\Users\yourname\.openclaw
OPENCLAW_HOME=

# OpenClaw Gateway connection
OPENCLAW_GATEWAY_HOST=127.0.0.1
OPENCLAW_GATEWAY_PORT=18789

# Gateway auth token (find yours with: openclaw config get auth.token)
OPENCLAW_GATEWAY_TOKEN=
NEXT_PUBLIC_GATEWAY_TOKEN=

# Frontend gateway connection (same host/port, use LAN IP if accessing from another device)
NEXT_PUBLIC_GATEWAY_HOST=127.0.0.1
NEXT_PUBLIC_GATEWAY_PORT=18789

# Allow hosts to access MC (comma-separated — add your LAN IP if needed)
MC_ALLOWED_HOSTS=localhost,127.0.0.1

# Memory browser (defaults to OPENCLAW_HOME workspace)
OPENCLAW_MEMORY_DIR=
OPENCLAW_MEMORY_ALLOWED_PREFIXES=

# OpenClaw tools profile
OPENCLAW_TOOLS_PROFILE=

# MC API key (auto-generated on first run, or set your own)
API_KEY=

# ─── AI Providers (optional — set the ones you have) ────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
OLLAMA_API_KEY=

# ─── Search & Scraping (optional) ───────────────────────────
FIRECRAWL_API_KEY=
APIFY_API_TOKEN=
BRAVE_API_KEY=

# ─── Social (optional) ──────────────────────────────────────
BSKY_HANDLE=
BSKY_APP_PASSWORD=
SCRAPECREATORS_API_KEY=

# ─── Dev Tools (optional) ───────────────────────────────────
GITHUB_TOKEN=
GH_TOKEN=
GOOGLE_PLACES_API_KEY=
